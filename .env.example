# AWS region where Bedrock Mantle is available
AWS_REGION=us-east-1

# Optional override. Defaults to https://bedrock-mantle.{AWS_REGION}.api.aws
# (host root — the proxy appends /v1/... or /anthropic/v1/... itself)
# MANTLE_BASE_URL=https://bedrock-mantle.us-east-1.api.aws

# Lifetime requested for each generated Bedrock bearer token (max 12h / 43200s)
BEDROCK_TOKEN_TTL_SECONDS=3600

# Timeout (seconds) for requests forwarded to Mantle
MANTLE_REQUEST_TIMEOUT_SECONDS=300

# Local server bind address/port
PROXY_HOST=0.0.0.0
PROXY_PORT=8000

# Optional override for the model_id -> contract ("anthropic"|"openai")
# mapping file. Defaults to app/model_contracts.json.
# MODEL_CONTRACTS_FILE=/path/to/model_contracts.json
